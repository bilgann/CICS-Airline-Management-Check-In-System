ART104B  DFHMDF POS=(11,41),LENGTH=40,ATTRB=(PROT,BRT),COLOR=NEUTRAL,  *
               INITIAL='/:/\:\__\ /::\:\__\ /::\:\__\            '
ART105A  DFHMDF POS=(12,1),LENGTH=40,ATTRB=(PROT,BRT),COLOR=NEUTRAL,   *
               INITIAL='  /:/\/__/ \/\::/  / \;:;-",-" \:\:\/  / '
ART105B  DFHMDF POS=(12,41),LENGTH=40,ATTRB=(PROT,BRT),COLOR=NEUTRAL,  *
               INITIAL=' \:\/:/  / \/\:\/__/ \/\:\/__/            '
