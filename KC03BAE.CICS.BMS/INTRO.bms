* TITLE SECTION
TITLE1   DFHMDF POS=(17,22),LENGTH=40,ATTRB=(PROT,BRT),COLOR=BLUE,     *
               INITIAL='CICS Airline Reservation Check In System'
TITLE2   DFHMDF POS=(19,34),LENGTH=15,ATTRB=(PROT,BRT),COLOR=BLUE,     *
               INITIAL='By Bilgan Kiris'
*
* INSTRUCTIONS
INST1    DFHMDF POS=(21,4),LENGTH=23,ATTRB=(PROT,BRT),COLOR=YELLOW,    *
               INITIAL='Press ENTER to Continue'
INST2    DFHMDF POS=(21,59),LENGTH=17,ATTRB=(PROT,BRT),COLOR=YELLOW,   *
               INITIAL='Press PF3 to Exit'
*
* MESSAGE LINE
MSGL    DFHMDF  POS=(24,1),LENGTH=4,ATTRB=(PROT,BRT)
MSGO    DFHMDF  POS=(24,6),LENGTH=74,ATTRB=(PROT,BRT),                 X000007
               COLOR=NEUTRAL,INITIAL='Ready'
